<mxfile host="app.diagrams.net"><diagram id="logic-revisi-maincpp" name="Menu Antrean Lab (FINAL)">
  <mxGraphModel dx="1200" dy="880" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
